# Neon Postgres - Obtener de https://neon.tech
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Vercel Blob - Se configura automáticamente al crear un Blob store en Vercel
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Multi-tenant
# El dominio base para los subdominios de cada tenant
BASE_DOMAIN=marcai.cl

# Resend - Emails transaccionales (https://resend.com)
RESEND_API_KEY=re_xxxxx
NOTIFICATION_FROM_EMAIL=notificaciones@marcai.cl

# Admin global (para gestión de tenants)
GLOBAL_ADMIN_SECRET=cambiar-por-algo-seguro
